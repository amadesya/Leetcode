class Solution(object):
    def searchRange(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        def binaryfirst(target,nums):
            low = 0
            high = len(nums)-1
            t = -1
            while low<=high:
                mid=low+(high-low)//2
                if nums[mid]<target:
                    low = mid+1
                elif nums[mid]==target:
                    t = mid
                    high = mid - 1
                else:
                    high = mid - 1
            return t

        def binarylast(target,nums):
            low = 0
            high = len(nums)-1
            t = -1
            while low<=high:
                mid=low+(high-low)//2
                if nums[mid]<target:
                    low = mid+1
                elif nums[mid]==target:
                    t = mid
                    low = mid + 1
                else:
                    high = mid - 1
            return t
        return (binaryfirst(target, nums), binarylast(target, nums))
    
